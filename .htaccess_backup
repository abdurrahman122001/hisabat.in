# Disable Directory Browsing
Options -Indexes
php_value max_input_vars 3000

# Protect .htaccess file itself
<Files .htaccess>
    Order Allow,Deny
    Deny from all
</Files>

# Block access to sensitive files
<FilesMatch "\.(env|ini|log|sh|bak|sql|json|xml|config)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Disable PHP execution in certain directories (e.g., uploads)
<Directory "/path/to/uploads">
    <FilesMatch "\.php$">
        Order Allow,Deny
        Deny from all
    </FilesMatch>
</Directory>