RewriteEngine On

# API and PHP endpoints - serve directly without SPA fallback
RewriteRule ^api/ - [L]
RewriteRule \.php$ - [L]

# Serve existing files/directories directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# SPA fallback: route everything else to the React app
RewriteRule ^ index.html [L]
